@model TaskItem

<h2>Create Task</h2>

<form asp-action="Create" method="post">
    <div>
        <label>Title</label>
        <input asp-for="TaskTitle" />
    </div>

    <div>
        <label>Description</label>
        <input asp-for="TaskDescription" />
    </div>

    <div>
        <label>Due Date</label>
        <input asp-for="TaskDueDate" type="date" />
    </div>

    <button type="submit">Save</button>
</form>