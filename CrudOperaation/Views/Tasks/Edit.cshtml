@model TaskItem

<h2>Edit Task</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div>
        <label>Title</label>
        <input asp-for="TaskTitle" />
    </div>

    <div>
        <label>Description</label>
        <input asp-for="TaskDescription" />
    </div>

    <div>
        <label>Due Date</label>
        <input asp-for="TaskDueDate" type="date" />
    </div>

    <div>
        <label>Status</label>
        <input asp-for="TaskStatus" />
    </div>

    <button type="submit">Update</button>
</form>
